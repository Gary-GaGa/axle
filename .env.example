# ===========================================
# Axle - Environment Configuration
# ===========================================

# [必填] Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# [必填] 允許的 Telegram User ID（逗號分隔，安全白名單）
# 可透過 @userinfobot 取得你的 User ID
ALLOWED_USER_IDS=123456789

# [選填] 工作目錄（Agent 的檔案操作範圍，預設為當前目錄）
WORKSPACE=.

# [選填] Email 設定（用於 Email 整合功能）
# EMAIL_ADDRESS=your@gmail.com
# EMAIL_PASSWORD=your_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
